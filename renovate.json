{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "semanticCommits": "enabled",
  "semanticCommitScope": "helm",
  "semanticCommitType": "build",
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update appVersion in Chart.yaml when new Docker image is published",
      "fileMatch": ["charts/nextcloud-mcp-server/Chart\\.yaml$"],
      "matchStrings": [
        "appVersion:\\s*\"(?<currentValue>[^\"]+)\""
      ],
      "depNameTemplate": "ghcr.io/cbcoutinho/nextcloud-mcp-server",
      "datasourceTemplate": "docker",
      "extractVersionTemplate": "^v?(?<version>.*)$"
    },
    {
      "customType": "regex",
      "description": "Update inline-annotated docker tags in values.yaml (e.g. qdrant sidecar)",
      "fileMatch": ["charts/.+/values\\.yaml$"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>[a-z-]+) depName=(?<depName>[^\\s]+)(?: versioning=(?<versioning>[^\\s]+))?\\s+tag:\\s*\"?(?<currentValue>[^\"\\s]+)\"?"
      ],
      "versioningTemplate": "{{#if versioning}}{{versioning}}{{else}}semver{{/if}}",
      "extractVersionTemplate": "^v?(?<version>.*)$"
    }
  ]
}
